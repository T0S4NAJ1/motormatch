# ============================================
# MotorMatch - Environment Configuration
# ============================================
# Salin file ini ke .env dan sesuaikan nilainya

# Database Configuration
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=motormatch_saw

# Server Configuration
PORT=3000

# Session Secret (untuk production, gunakan string acak yang panjang)
SESSION_SECRET=motormatch_secret_key_change_in_production

# Environment
NODE_ENV=development
